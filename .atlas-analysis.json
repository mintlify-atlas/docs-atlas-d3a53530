  "keyFeatures": [
    "Project and partner management with location tracking",
    "Equipment and vehicle resource allocation and tracking",
    "Work order management with custody chains",
    "Maintenance scheduling and sheets",
    "Technical staff management with certifications and vaccinations",
    "Document management with PDF generation and merging",
    "Calendar-based resource scheduling",
    "Shipping guide generation"
  ],
  "publicApiSurface": [
    "POST /api/projects/resources/add/ - Add resource to project",
    "DELETE /api/projects/resources/delete/<id>/ - Remove resource from project",
    "GET /api/projects/resources/available/ - List available resources",
    "POST /api/projects/<id>/close/ - Close a project",
    "GET /api/projects/<id>/resources/ - Get project resources",
    "POST /api/vehicles/cert_vehicle/ - Manage vehicle certifications",
    "POST /api/vehicles/pass_vehicle/ - Manage vehicle passes",
    "GET /api/vehicles/avaliables/ - List available vehicles",
    "POST /api/technicals/create_update_pass_technical/ - Manage technical passes",
    "POST /api/technicals/create_update_vaccine/ - Manage vaccination records",
    "GET /api/technicals/avaliables/ - List available technicians",
    "POST /api/workorders/sheets/create/ - Create work sheet",
    "POST /api/workorders/custody_chain/create/ - Create custody chain",
    "GET /api/workorders/sheets/project/<id>/ - Get project sheets",
    "POST /api/load_files/ - Upload files",
    "POST /api/load_files/project/<id>/merge/ - Merge project documents",
    "POST /api/shipping/guides/ - Create shipping guide",
    "POST /api/maintenance/sheets/ - Create maintenance sheet",
    "POST /api/calendar/events/ - Create calendar event"
  ]
